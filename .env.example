# ============================================================
# XDART-Φ × XHEART — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── LLM Provider ──
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_THINKING_ENABLED=true
OPENAI_MAX_TOKENS=16384
OPENAI_TEMPERATURE=0.7

# ── Embeddings (OpenAI) ──
EMBEDDING_API_KEY=***REMOVED***
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Qdrant ──
QDRANT_COLLECTION=xheart_states
QDRANT_VECTOR_SIZE=1536

# ── Framework ──
XDART_MIN_DOMAINS=10
XDART_MAX_VIEWS=18
XHEART_MEMORY_TOP_K=3
LAYER3_THRESHOLD=4

# ── Perception ──
PERCEPTION_ENABLED=true
FRED_API_KEY=your-fred-key
FINNHUB_API_KEY=your-finnhub-key

# ── Search ──
SEARCH_ENGINE_ORDER=searxng,brave,duckduckgo
BRAVE_SEARCH_API_KEY=your-brave-key

# ── Proactive ──
PROACTIVE_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── ElevenLabs (optional) ──
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Feature Flags ──
META_ORCHESTRATOR_ENABLED=true
EVOLUTION_ENABLED=true
CURIOSITY_ENABLED=true
QUANTUM_ENABLED=true
BAYESIAN_FUZZY_ENABLED=true

# ── CORS (production: your domain only) ──
CORS_ORIGINS=*

# ── Logging ──
LOG_LEVEL=INFO
