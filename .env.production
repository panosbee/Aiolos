# ============================================================
# XDART-Φ × XHEART — Production Environment Configuration
# ============================================================
# Copy to .env and fill in ALL values before deploying.
# NEVER commit .env to git — it contains secrets.
#
# © Panos Skouras — Salimov MON IKE, 2026
# ============================================================

# ── LLM Provider (DeepSeek) ──
OPENAI_API_KEY=***REMOVED***
OPENAI_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_THINKING_ENABLED=true
OPENAI_MAX_TOKENS=16384
OPENAI_TEMPERATURE=0.7
LLM_MAX_CONTEXT_TOKENS=131072

# ── Embeddings (OpenAI — DeepSeek has no embedding API) ──
EMBEDDING_API_KEY=***REMOVED***
EMBEDDING_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Qdrant (Embedded Mode — paths set by docker-compose) ──
QDRANT_COLLECTION=xheart_states
QDRANT_VECTOR_SIZE=1536

# ── Perception Layer ──
PERCEPTION_ENABLED=true
FRED_API_KEY=your-fred-api-key
FINNHUB_API_KEY=your-finnhub-api-key
PERCEPTION_HOURS_BACK=72
PERCEPTION_MAX_EVENTS=10
PERCEPTION_MAX_ECONOMIC=5

# ── UCDP (Uppsala Conflict Data Program) ──
UCDP_API_TOKEN=***REMOVED***
# ── Web Agent ──
WEB_AGENT_ENABLED=true
WEB_AGENT_RESPECT_ROBOTS=true

# ── Search Engines ──
SEARCH_ENGINE_ORDER=searxng,brave,duckduckgo
SEARXNG_URL=http://searxng:8080
BRAVE_SEARCH_API_KEY=your-brave-search-key

# ── Proactive Communication ──
PROACTIVE_ENABLED=true
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── ElevenLabs Voice (optional) ──
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_TTS=eleven_v3
ELEVENLABS_MODEL_STT=scribe_v2

# ── Framework Features ──
XDART_MIN_DOMAINS=10
XDART_MAX_VIEWS=18
XHEART_MEMORY_TOP_K=3
LAYER3_THRESHOLD=4
META_ORCHESTRATOR_ENABLED=true
EVOLUTION_ENABLED=true
CURIOSITY_ENABLED=true
QUANTUM_ENABLED=true
BAYESIAN_FUZZY_ENABLED=true
BAYESIAN_FUZZY_PRIOR_WEIGHT=1.5

# ── Logging ──
LOG_LEVEL=INFO

# ── CORS (comma-separated allowed origins for production) ──
CORS_ORIGINS=https://your-domain.com

# ── SearXNG Secret ──
SEARXNG_SECRET=change-this-to-a-random-string
